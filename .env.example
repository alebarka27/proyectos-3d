# === Base de datos (Vercel Postgres) ===
# Obtenela desde: https://vercel.com/dashboard/stores
POSTGRES_URL=postgres://default:password@host:5432/verceldb

# === Autenticacion del panel admin ===
# Contraseña del unico usuario admin. Usá una larga y unica.
ADMIN_PASSWORD=cambia-esta-contraseña

# Secret para firmar las cookies de sesion (HMAC-SHA256).
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=pega-aca-un-secret-aleatorio-largo

# === Mercado Libre API ===
# Obtenelos desde: https://developers.mercadolibre.com
ML_CLIENT_ID=your_client_id_here
ML_CLIENT_SECRET=your_client_secret_here
ML_REDIRECT_URI=https://proyectos-3d.vercel.app/api/ml/callback
