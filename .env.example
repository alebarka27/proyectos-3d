# === Base de datos (Vercel Postgres) ===
# Obtenela desde: https://vercel.com/dashboard/stores
POSTGRES_URL=postgres://default:password@host:5432/verceldb

# === Autenticacion del panel admin ===
# Contraseña del unico usuario admin. Usá una larga y unica.
ADMIN_PASSWORD=cambia-esta-contraseña

# Secret para firmar las cookies de sesion (HMAC-SHA256).
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=pega-aca-un-secret-aleatorio-largo

# === Mercado Libre API ===
# Obtenelos desde: https://developers.mercadolibre.com
ML_CLIENT_ID=your_client_id_here
ML_CLIENT_SECRET=your_client_secret_here
ML_REDIRECT_URI=https://proyectos-3d.vercel.app/api/ml/callback

# === Google Drive (entrega de archivos digitales / STL) ===
# Service account de Google Cloud con la API de Google Drive habilitada.
# 1. console.cloud.google.com -> crear proyecto -> habilitar "Google Drive API"
# 2. Crear Service Account -> Keys -> Add Key -> JSON (descargar)
# 3. Compartir tu carpeta de STLs en Drive con el email del service account (como lector)
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-sa@tu-proyecto.iam.gserviceaccount.com
# La private_key del JSON. Pegá el valor completo entre comillas, con los \n literales.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Archivos digitales mas pesados que esto (MB) se entregan redirigiendo directo a
# Drive en vez de pasar por el servidor. Esos archivos deben estar compartidos como
# "cualquiera con el enlace". Default: 80.
DESCARGA_PROXY_MAX_MB=80
